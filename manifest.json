{
  "manifest_version": 3,
  "name": "leegle-gpt-image-downloader",
  "short_name": "leegle-gpt-image-downloader",
  "version": "0.0.18",
  "description": "Batch download ChatGPT generated images as high-resolution ZIP files. Includes Chinese/English UI and bilingual installation guides. Local-only, no upload.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "leegle-gpt-image-downloader"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "contentScript.js"
      ],
      "run_at": "document_idle"
    }
  ]
}